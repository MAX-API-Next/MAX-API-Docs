# Host port exposed by Docker Compose.
DOCS_PORT=33301

# Public deployment URL. This value is embedded during image build.
NEXT_PUBLIC_SITE_URL=https://docs.example.com

# Optional Google Analytics measurement ID.
NEXT_PUBLIC_GA_ID=

# Optional Ask AI configuration. The API key is injected only at runtime.
INKEEP_API_KEY=
AI_MODEL=inkeep-qa-sonnet-4
AI_BASE_URL=https://api.inkeep.com/v1

# Optional GitHub App credentials for documentation feedback.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
